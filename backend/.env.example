# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=your_webhook_verify_token_here
META_ACCESS_TOKEN=your_meta_permanent_access_token_here
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# SMS defaults
# Each Nexa client can override these credentials from the SMS Provider page.
SMS_PROVIDER=blessed
BLESSED_API_KEY=your_blessed_text_api_key
BLESSED_SENDER_ID=your_blessed_text_sender_id
BLESSED_API_URL=https://sms.blessedtexts.com/api/sms/v1/sendsms
SAVVY_API_KEY=your_savvy_api_key
SAVVY_PARTNER_ID=your_savvy_partner_id
SAVVY_SENDER_ID=your_savvy_sender_id
SAVVY_API_URL=https://sms.savvybulksms.com/api/services/sendsms/

# PostgreSQL — use docker-compose for local dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_support

# Auth
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Server
PORT=3001

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173
