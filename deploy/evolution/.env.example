# Nexa Official WhatsApp Number - Evolution API
# Copy this file to .env on the droplet and replace the CHANGE_ME values.
# Never commit the completed .env file containing secrets.

# Docker service passwords
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# Server
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://evoapi.telenexustechnologies.com

# Evolution API authentication
AUTHENTICATION_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# Keep linked Nexa WhatsApp instance unless manually deleted
DEL_INSTANCE=false

# Persistent database used by Evolution API
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:CHANGE_ME_POSTGRES_PASSWORD@evolution-postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=nexa_operator
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# Redis cache/session support
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:CHANGE_ME_REDIS_PASSWORD@evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=nexa_operator
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# Nexa will configure the instance webhook later
WEBHOOK_GLOBAL_ENABLED=false
WEBSOCKET_ENABLED=false

# QR-linked phone identity
CONFIG_SESSION_PHONE_CLIENT=Nexa Official Agent
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30

# Logs
LOG_LEVEL=ERROR,WARN,INFO,LOG,WEBHOOKS
LOG_BAILEYS=error
LOG_COLOR=true

# Initial setup access. Restrict later when integrating the admin panel.
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true
LANGUAGE=en
